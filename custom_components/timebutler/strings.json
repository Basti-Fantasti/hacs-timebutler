{
  "config": {
    "step": {
      "user": {
        "title": "Connect to Timebutler",
        "description": "Enter your Timebutler API token. You can find this in your Timebutler account settings.",
        "data": {
          "api_token": "API Token"
        }
      }
    },
    "error": {
      "cannot_connect": "Failed to connect to Timebutler API",
      "invalid_auth": "Invalid API token or API access has been deactivated",
      "unknown": "Unexpected error"
    },
    "abort": {
      "already_configured": "This Timebutler account is already configured"
    }
  },
  "options": {
    "step": {
      "init": {
        "title": "Timebutler Options",
        "description": "Configure the update interval for Timebutler data.",
        "data": {
          "scan_interval": "Update interval (seconds)"
        }
      }
    }
  },
  "entity": {
    "sensor": {
      "user_status": {
        "name": "{name}",
        "state": {
          "working": "Working",
          "paused": "On break",
          "off": "Off",
          "vacation": "Vacation",
          "sickness": "Sick"
        }
      },
      "people_working": {
        "name": "People working"
      },
      "people_on_break": {
        "name": "People on break"
      },
      "people_on_vacation": {
        "name": "People on vacation"
      },
      "people_on_sickness": {
        "name": "People sick"
      },
      "people_working_department": {
        "name": "{department} - Working"
      },
      "people_on_break_department": {
        "name": "{department} - On break"
      },
      "people_on_vacation_department": {
        "name": "{department} - On vacation"
      },
      "people_on_sickness_department": {
        "name": "{department} - Sick"
      }
    }
  }
}
